HOST=127.0.0.1
PORT=3000

# Optional payments integration
STRIPE_SECRET_KEY=
STRIPE_SUCCESS_URL=
STRIPE_CANCEL_URL=
STRIPE_MIN_AMOUNT_CENTS=50
STRIPE_MAX_AMOUNT_CENTS=200000
MAX_JSON_BODY_BYTES=65536
PUBLIC_SITE_ORIGIN=https://shynlicleaningservice.com
GOOGLE_PLACES_API_KEY=
QUOTE_SIGNING_SECRET=
QUOTE_TOKEN_TTL_SECONDS=900

# Optional LeadConnector / GHL quote CRM integration
GHL_API_KEY=
GHL_LOCATION_ID=
GHL_API_BASE_URL=https://services.leadconnectorhq.com
GHL_API_VERSION=2021-07-28
GHL_CONTACT_SOURCE=Website Calculator
GHL_CONTACT_TAGS=Calculator,Price Calculation,Booking,Website
GHL_CREATE_OPPORTUNITY=1
GHL_ENABLE_NOTES=1
GHL_REQUEST_TIMEOUT_MS=10000
GHL_NOTE_MAX_LENGTH=4000
GHL_PIPELINE_ID=
GHL_PIPELINE_STAGE_ID=
GHL_PIPELINE_NAME=Pipelines Main
GHL_PIPELINE_STAGE_NAME=New Lead
# Optional JSON object mapping logical quote fields to GHL custom field IDs.
# Example: {"fullName":"abc123","serviceType":"def456","totalPrice":"ghi789"}
GHL_CUSTOM_FIELDS_JSON=

# Optional admin access controls
# If ADMIN_MASTER_SECRET is empty, the server falls back to QUOTE_SIGNING_SECRET,
# GHL_API_KEY, or STRIPE_SECRET_KEY for signing admin sessions and deriving TOTP.
ADMIN_EMAIL=info@shynli.com
ADMIN_PASSWORD_HASH=
ADMIN_MASTER_SECRET=
ADMIN_TOTP_SECRET=
ADMIN_TOTP_ISSUER=SHYNLI Admin
ADMIN_LOGIN_RATE_LIMIT_WINDOW_MS=600000
ADMIN_LOGIN_RATE_LIMIT_MAX_REQUESTS=5
ADMIN_2FA_RATE_LIMIT_WINDOW_MS=600000
ADMIN_2FA_RATE_LIMIT_MAX_REQUESTS=10

# Runtime and performance tuning
HTML_CACHE_WARM_MODE=minimal
REQUEST_LOG_BUFFER_LIMIT=4000
REQUEST_LOG_FLUSH_INTERVAL_MS=250
POST_RATE_LIMIT_WINDOW_MS=60000
POST_RATE_LIMIT_MAX_REQUESTS=10
TRUST_PROXY_HEADERS=0
TRUSTED_PROXY_IPS=
ENABLE_PERF_ENDPOINT=0
PERF_ENDPOINT_TOKEN=
PERF_WINDOW_MS=300000
PERF_SUMMARY_INTERVAL_MS=60000
PERF_MAX_SAMPLES=40000
ALERT_P95_MS=500
ALERT_P99_MS=1000
ALERT_5XX_RATE=0.01
ALERT_EVENT_LOOP_P95_MS=100

# Optional Cloudflare purge script env
CF_API_TOKEN=
CF_ZONE_ID=
SITE_BASE_URL=https://shynlicleaningservice.com
CF_PURGE_EVERYTHING=0
